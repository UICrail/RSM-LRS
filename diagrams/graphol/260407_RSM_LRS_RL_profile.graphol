              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://purl.org/vocab/vann/preferredNamespaceUri</property>
              <object>
                <iri>https://cdm.ovh/rsm/linearReferencing/rlrs</iri>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://purl.org/dc/elements/1.1/creator</property>
              <object>
                <lexicalForm>Airy Magnien, UIC</lexicalForm>
                <datatype/>
                <language/>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://purl.org/dc/elements/1.1/title</property>
              <object>
                <lexicalForm>Linear Referencing ontology</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://purl.org/dc/elements/1.1/description</property>
              <object>
                <lexicalForm>Linear referencing ontology based on ISO 19148:2021. Adds the notion of intrinsic coordinate used by the RSM localisation ontology.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://purl.org/dc/terms/created</property>
              <object>
                <lexicalForm>28 May 2026</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://purl.org/dc/terms/license</property>
              <object>
                <iri>https://creativecommons.org/licenses/by-sa/4.0/</iri>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://www.w3.org/2002/07/owl#versionInfo</property>
              <object>
                <lexicalForm>0.2 added: vertical and lateral offsets (ISO 19148), as well as longitudinal offset (not in ISO)</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://www.w3.org/2002/07/owl#versionInfo</property>
              <object>
                <lexicalForm>0.3: added LinearReferencingSystem and Anchor points for backward compatibility with RTM/RSM; 'syntactic sugar' using the ISO19148 concepts.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://www.w3.org/2002/07/owl#versionInfo</property>
              <object>
                <lexicalForm>0.4 Corrected erroneous reference to dul:Concept instead of skos:Concept. Replaced two "oneOf" constructions by references to corresponding skos concept schemes for linear referencing methods.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://www.w3.org/2002/07/owl#versionInfo</property>
              <object>
                <lexicalForm>0.5: QuantityValue namespace corrected to qudt:</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://www.w3.org/2002/07/owl#versionInfo</property>
              <object>
                <lexicalForm>0.6: removed subclass link between Referent and loca:SpotLocation (they are just "not disjoint")</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>This particular version attempts to stay in the OWL2 RL profile. For that purpose, all existential restrictions on superclasses were removed.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>

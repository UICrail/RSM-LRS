              <object>
                <lexicalForm>lateral offset</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/linearReferencing/rlrs#lateralOffset</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>unit: meter; positive on right side w.r.t. linear element orientation (port 0 to port 1)</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
